generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Entry {
  id                  String               @id @default(cuid())
  entryNumber         Int?                 @unique
  beanName            String?
  drinkLabel          String?
  title               String?
  cafeName            String?
  roasterName         String?
  dateTried           DateTime?
  city                String?
  countryWhereDrank   String?
  originCountry       String?
  originRegion        String?
  producer            String?
  farm                String?
  varietal            String?
  process             String?
  tastingNotesRaw     String?
  servedStyle         ServedStyle?
  personalTastingNote String?
  whatLingered        String?
  roomNote            String?
  selectionSource     SelectionSource?
  selectedBy          String?
  curationNote        String?
  memoryNote          String?
  memoryTrip          Boolean              @default(false)
  turningPoint        Boolean              @default(false)
  quietFavorite       Boolean              @default(false)
  wouldRevisit        Boolean              @default(false)
  postStatus          PostStatus           @default(NOT_PLANNED)
  photoReadiness      PhotoReadiness       @default(NO_PHOTOS)
  sourceType          SourceType           @default(CURRENT_CUP)
  confidence          Confidence           @default(MEDIUM)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  media               Media[]
  entryThemes         EntryTheme[]
  contentDrafts       ContentDraft[]
  entryCollections    EntryCollection[]
  interpretation      EntryInterpretation?
}

model Media {
  id            String    @id @default(cuid())
  entryId       String
  type          MediaType
  storagePath   String
  extractedText String?
  aiDescription String?
  createdAt     DateTime  @default(now())
  entry         Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model Theme {
  id          String        @id @default(cuid())
  name        String        @unique
  category    ThemeCategory
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  entryThemes EntryTheme[]
}

model EntryTheme {
  id         String      @id @default(cuid())
  entryId    String
  themeId    String
  source     ThemeSource @default(MANUAL)
  confidence Float?
  entry      Entry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  theme      Theme       @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([entryId, themeId])
}

model ContentDraft {
  id          String      @id @default(cuid())
  entryId     String
  type        DraftType
  content     String
  modelSource DraftSource @default(MANUAL)
  createdAt   DateTime    @default(now())
  entry       Entry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entryCollections EntryCollection[]
}

model EntryCollection {
  id           String @id @default(cuid())
  entryId      String
  collectionId String

  entry      Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([entryId, collectionId])
}

enum ServedStyle {
  HOT
  ICED
  BOTH
}

enum PostStatus {
  NOT_PLANNED
  STORY_ONLY
  MAIN_POST_CANDIDATE
  DRAFTING
  SCHEDULED
  PUBLISHED
}

enum PhotoReadiness {
  NO_PHOTOS
  CARD_ONLY
  CUP_PHOTO_AVAILABLE
  ROOM_PHOTO_AVAILABLE
  FULL_CAROUSEL_READY
}

enum SourceType {
  CURRENT_CUP
  OLD_BEAN_CARD
  MEMORY_TRIP
  MENU_ENTRY
  STORY_NOTE
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

enum MediaType {
  BEAN_CARD
  CUP
  ROOM
  POST_DRAFT
  STORY_DRAFT
  OTHER
}

enum ThemeCategory {
  SENSORY
  EXPERIENCE
  PERSONAL_ARCHIVE
  CUSTOM
}

enum ThemeSource {
  MANUAL
  AI
}

enum DraftType {
  CAPTION
  HAIKU
  ROOM_NOTE
  TEASER
  STORYBOARD
  WHAT_LINGERED
}

enum DraftSource {
  MANUAL
  AI
}

model EntryInterpretation {
  id      String @id @default(cuid())
  entryId String @unique
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  // Context
  occasion Occasion?

  // Choice logic
  selectionSource SelectionSource?
  selectionIntent SelectionIntent?

  // Internal state before coffee
  moodBefore   MoodState?
  energyBefore EnergyLevel?
  energyAfter  EnergyLevel?

  // Outcome / fit
  momentFitRating  Int?
  repeatLikelihood RepeatLikelihood?

  // Reflective interpretation
  interpretationNote String?
  memoryNote         String?
  lingeringNote      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Occasion {
  JOURNALING
  READING
  WORK_FOCUS
  CREATIVE_WORK
  SOCIAL_CATCHUP
  SOLO_WANDERING
  TRAVEL
  MEMORY_VISIT
  HOME_BREWING
  ROUTINE_CUP
  OTHER
  UNKNOWN
}

enum SelectionSource {
  SELF_SELECTED
  BARISTA_RECOMMENDED
  FRIEND_RECOMMENDED
  CAFE_SIGNATURE
  CAFE_FEATURED
  TASTING_FLIGHT
  ROASTER_FEATURE
  SOCIAL_MEDIA
  MENU_DESCRIPTION
  SUBSCRIPTION_SET
  RETURNING_FAVORITE
  RANDOM_CHOICE
  GIFT
  OTHER
  UNKNOWN
}

enum SelectionIntent {
  CURIOSITY
  COMFORT
  CLARITY
  ENERGY_RESET
  TREAT
  EXPERIMENT
  MEMORY
  SOCIAL_PAIRING
  ROUTINE
  NOVELTY
  OTHER
  UNKNOWN
}

enum MoodState {
  CURIOUS
  FOCUSED
  REFLECTIVE
  CALM
  TIRED
  RESTLESS
  COMFORT_SEEKING
  SOCIAL
  NEUTRAL
  OTHER
  UNKNOWN
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

enum RepeatLikelihood {
  YES
  MAYBE
  ONLY_IN_SAME_CONTEXT
  NO
  UNKNOWN
}
